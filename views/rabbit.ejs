<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title><%= character.name %> — <%= character.title %></title>
    <link rel="stylesheet" href="style.css">
</head>
<body>
    <div id="loader">
        <div class="spinner"></div>
        <p>Summoning <%= character.name %>...</p>
    </div>

    <header class="character-hero">
        <div class="character-image">
            <img src="<%= character.imageUrl %>" alt="<%= character.name %>">
        </div>
        <div class="character-info">
            <h1><%= character.name %></h1>
            <p class="character-title">🌌 <%= character.title %></p>
            <div class="rank-badge"><%= character.rank %></div>
        </div>
    </header>

    <section class="lore-section">
        <h2>Legendary Lore</h2>
        <p><%= character.lore %></p>
    </section>

    <section class="abilities-section">
        <h2>Celestial Abilities</h2>
        <% character.abilities.forEach(ability => { %>
            <div class="ability-card">
                <h3><%= ability.icon %> <%= ability.name %></h3>
                <p><%= ability.description %></p>
                <div class="power-bar">
                    <div style="width: <%= ability.power %>%"></div>
                </div>
            </div>
        <% }); %>
    </section>

    <nav class="nav-back">
        <a href="/">← Return to Homepage</a>
    </nav>

    <script>
        setTimeout(() => {
            document.getElementById("loader").style.display = "none";
        }, 900);
    </script>
</body>
</html>